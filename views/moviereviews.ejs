<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= movieData.title %> | Movie Reviews</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="topnav">
    <a class="active" href="/">Home</a>
    <% if (isLoggedIn) { %>
        <a href="/account">User Account</a>
        <a href="/watchlist">Watchlist</a>
        <a href="/logout">Logout</a>
    <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
    <% } %>
</div>

    <div class="movie-header">
        <% if (movieData.poster) { %>
            <img src="<%= movieData.poster %>" alt="<%= movieData.title %> poster" class="movie-poster" />
        <% } else { %>
            <div style="width:250px; height:375px; background:#ccc; display:flex; align-items:center; justify-content:center;">No Image</div>
        <% } %>
        
        <div>
            <form action="/watchlist/createMovie" method="post">
            <h2><%= movieData.title %></h2>
            <p><strong>Release Date:</strong> <%= movieData.releaseDate %></p>
            <p><strong>Community Average Rating:</strong> 
                <% if (averageRating !== null) { %>
                    <%= averageRating %> / 10
                <% } else { %>
                    -/10 (No reviews yet)
                <% } %>
            </p>
            <p><strong>Overview:</strong><br><%= movieData.overview %></p>
            <input type="hidden" name="movie" value="<%=movieData.title%>"> <!--Input hidden sends data to watchlist-->
            <input type="hidden" name="rating" value="<%=averageRating%>">
            <input type="hidden" name="id" value="<%=movieData.id%>">
            <button type="submit">Add to Watchlist</button>
            </form>
            <div style="margin-top: 20px;">
                <h3>Trailer</h3>
                <% if (movieTrailer) { %>
                    <iframe
                        width="420"
                        height="236"
                        src="<%= movieTrailer.embedUrl %>"
                        title="<%= movieTrailer.trailerName %>"
                        allowfullscreen
                    ></iframe>
                    <br>
                    <a href="<%= movieTrailer.url %>" target="_blank">Open on YouTube</a>
                <% } else { %>
                    <p>No trailer found.</p>
                <% } %>

                <% if (isAdmin && movieTrailer) { %>
                    <% if (hasSavedTrailer) { %>
                        <form action="/update-trailer/<%= movieData.id %>" method="POST" class="inline-action-form">
                            <input type="hidden" name="movieName" value="<%= movieData.title %>">
                            <button type="submit">Update Trailer</button>
                        </form>
                        <form action="/delete-trailer/<%= movieData.id %>" method="POST" class="inline-action-form" onsubmit="return confirm('Are you sure you want to delete this trailer?');">
                            <button type="submit">Delete Trailer</button>
                        </form>
                    <% } else { %>
                        <form action="/movie-trailer/<%= movieData.id %>" method="POST">
                            <input type="hidden" name="movieName" value="<%= movieData.title %>">
                            <button type="submit">Save Trailer</button>
                        </form>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>
    <div class="movie-stats">
    <p>👁️ Total Views: <%= viewCount %></p>
</div>


   <% if (isLoggedIn) { %>
    <form action="/movie-reviews/<%= movieData.id %>" method="POST">
        <h3>Submit a Review</h3>
        <label for="rating">Your rating (1-10):</label><br>
        <input type="number" name="rating" id="rating" min="1" max="10" required style="width: 50px;" />
        <br><br>
        <label for="description">Comment:</label><br>
        <textarea name="description" id="description" rows="5" cols="50" placeholder="What did you think of the movie?" required></textarea>
        <br><br>
        <button type="submit">Send Review</button>
    </form>
<% } else { %>
    <div style="background: #eee; padding: 20px; border-radius: 8px; margin-top: 30px; text-align: center;"> <!--If the user is not logged in, he will be prompted to log in. But he can still read the reviews-->
        <p>Want to share your thoughts? <a href="/login">Login</a> to post a review!</p>
    </div>
<% } %>

  <h2>User Reviews</h2>

  <% if (movieReviews.length > 0) { %>
    <% movieReviews.forEach(function(review) { %>
        <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; border-radius: 5px;">
       <div class="review-card">
        <% if (editId && String(editId) === String(review._id) && isLoggedIn && currentUser && (String(review.userId) === String(currentUser.id) || isAdmin)) { %> 
<form action="/update-review/<%= review._id %>/<%= movieData.id %>" method="POST"> 
    <input type="number" name="rating" value="<%= review.rating %>" min="1" max="10" required />
    <br>
            <textarea name="description" rows="3" style="width:100%"><%= review.reviewContent %></textarea>
            <br>
            <button type="submit">Save Changes</button>
            <a href="/movie-reviews/<%= movieData.id %>">Cancel</a>
        </form>
        <% } else { %>
      
        <div class="review-header">
            <p><strong><%= review.username %></strong> rated it <strong><%= review.rating %>/10</strong></p>
            <small>Posted on: <%= new Date(review.createdAt).toLocaleString() %></small>
        </div>
        
        <div class="review-body">
            <p><%= review.reviewContent %></p>
        </div>
        <% if (isLoggedIn && currentUser && (String(review.userId) === String(currentUser.id)|| isAdmin)) { %>
            <a href="/movie-reviews/<%= movieData.id %>?editId=<%= review._id %>" 
                           style="color: blue; text-decoration: none; margin-right: 15px; font-weight: bold;"> <!--If the user was the one that commented, an edit button will show which allows them to 
                                                                                                                render the same page but with the editId in the query-->
                                                                                                                <!--This will be checked by checking the userId and whether each review in the review schema has the same id-->
                                                                                                                <!--We do not use a form here because we are not submitting any data yet. We just want to
                                                                                                                Refresh the page so that it shows a textbox that then allows us to send data to the database-->
                           Edit Review
                        </a>
    <form action="/delete-review/<%= review._id %>/<%= movieData.id %>" method="POST" class="inline-action-form" onsubmit="return confirm('Are you sure you want to delete this review?');"> <!--- This allows users to delete the comment and confirms using onsubmit to check if they really want to delete-->
        <button type="submit" class="danger-btn">Delete Review</button>
    </form>
<% }} %>
      </div>
    <%}) %>
  <% } else { %>
    <p>No reviews yet. Be the first to post one!</p>
  <% } %>
  
</body>
</html>
