<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= movieData.title %> | Movie Reviews</title>
    <!-- <style>
        body { font-family: sans-serif; line-height: 1.6; padding: 20px; max-width: 800px; margin: auto; }
        .topnav { background: #333; overflow: hidden; padding: 10px; margin-bottom: 20px; }
        .topnav a { color: white; text-decoration: none; padding: 14px 16px; }
        .movie-header { display: flex; gap: 20px; margin-bottom: 30px; }
        .movie-poster { width: 250px; border-radius: 8px; }
        .review-card { border-bottom: 1px solid #ddd; padding: 15px 0; }
        .rating-badge { background: #f4c430; padding: 2px 6px; border-radius: 4px; font-weight: bold; }
        form { background: #f9f9f9; padding: 20px; border-radius: 8px; margin-top: 30px; }
    </style> -->
</head>
<body>
    <div class="topnav">
        <a class="active" href="/">Home</a>
        <a href="#">User Account</a>
        <a href="#">Watchlist</a>
        <a href="#">Logout</a>
    </div>

    <div class="movie-header">
        <% if (movieData.poster) { %>
            <img src="<%= movieData.poster %>" alt="<%= movieData.title %> poster" class="movie-poster" />
        <% } else { %>
            <div style="width:250px; height:375px; background:#ccc; display:flex; align-items:center; justify-content:center;">No Image</div>
        <% } %>
        
        <div>
            <form action="/watchlist/createMovie" method="post">
            <h2><%= movieData.title %></h2>
            <p><strong>Release Date:</strong> <%= movieData.releaseDate %></p>
            <p><strong>TMDB Average Rating:</strong> <%= movieData.rating %> / 10</p>
            <p><strong>Overview:</strong><br><%= movieData.overview %></p>
            <input type="hidden" name="movie" value="<%=movieData.title%>">
            <input type="hidden" name="rating" value="<%=movieData.rating%>">
            <input type="hidden" name="id" value="<%=movieData.id%>">
            <button type="submit">Add to Watchlist</button>
            </form>
        </div>
    </div>

    <hr />

    <h2>User Reviews</h2>
    <div id="reviews-list">
        <% if (movieReviews && movieReviews.length > 0) { %>
            <% movieReviews.forEach(function(review) { %>
                <div class="review-card">
                    <span class="rating-badge">Score: <%= movieReviews.rating %>/10</span>
                    <strong> - <%= movieReviews.username || 'Anonymous' %></strong>
                    <p><%= movieReviews.reviewContent %></p>
                </div>
            <% }); %>
        <% } else { %>
            <p>No reviews yet for this movie. Be the first to share your thoughts!</p>
        <% } %>
    </div>

    <form action="/movie-reviews/<%= movieData.id %>" method="POST">
        <h3>Submit a Review</h3>
        
        <label for="rating">Your rating (1-10):</label><br>
        <input type="number" name="rating" id="rating" min="1" max="10" required style="width: 50px;" />
        
        <br><br>
        
        <label for="description">Comment:</label><br>
        <textarea name="description" id="description" rows="5" cols="50" placeholder="What did you think of the movie?" required></textarea>
        
        <br><br>
        
        <button type="submit" style="padding: 10px 20px; cursor: pointer;">Send Review</button>
    </form>

  <h2>User Reviews</h2>

  <% if (movieReviews.length > 0) { %>
    <% movieReviews.forEach(function(r) { %>
      <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; border-radius: 5px;">
        <p><strong><%= r.username %></strong> rated it <strong><%= r.rating %>/10</strong></p>
        <p><%= r.reviewContent %></p>
        <form action="/delete-review/<%= r._id %>/<%= movieData.id %>" method="POST" style="display:inline;">
                <button type="submit" style="color: red; cursor: pointer;">
                    Delete Review
                </button>
            </form>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet. Be the first to post one!</p>
  <% } %>
  
</body>
</html>