<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
        <div class="topnav">
      <a class="active" href="#">Home</a>
      <a href="#">User Account</a>
      <a href="/watchlist">Watchlist</a>
      <a href="/login-page">Logout</a>
    </div>
    <h1>My Watchlist</h1>
    <table border="1">
        <tr>
            <th>Movie</th>
            <th>Rating</th>
            <th>Added</th>
            <th>Watched</th>
            <th>Actions</th>
        </tr>
        
        <% for (let movie of movies) { %>
        <tr>
            <td><a href="#"><%=movie.title %></a></td>
            <td>★ <%=movie.review %></td>
            <td><%=movie.date %></td>
            <!-- If movie has not been watched, don't display a tick symbol -->
            <% if (movie.isWatched == "No") { %>
            <td><%=movie.isWatched %></td>
            <!-- Else, display a tick symbol -->
            <% } else { %>
            <td>✔ <%=movie.isWatched %></td>
            <% } %>
            <td>
                <!--If movie has not been watched yet, display the "Mark Watched" button to allow user to mark movie as watched-->
                <% if (movie.isWatched == "No") { %>
                <form action="/markWatched" method="post">
                <input type="hidden" name="movie" value="<%=movie.title%>">
                <button type="submit">Mark Watched</button>
                <br>
                <br>
                </form>
                <!-- Else, just display the Remove button to allow user to remove movie from watchlist-->
                <% } %>
                <form action="/removeMovie" method="post">
                <input type="hidden" name="movie" value="<%=movie.title%>">
                <button type="submit">Remove</button>
                </form>
                <!-- -->
            </td>
        </tr>
        <% } %>
         
    </table>
    <br>
    <a href="#"><button type="button">Browse Movies</button></a>  
</body>
</html>